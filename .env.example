# Production: cp .env.example .env for docker compose

# ===== Database =====
POSTGRES_DB=horizon
POSTGRES_USER=horizon
POSTGRES_PASSWORD=horizon
POSTGRES_PORT=55432

# ===== Backend (Spring Boot) =====
APP_PORT=9080
# 로컬에서 Docker DB에 붙을 때 override (예: jdbc:postgresql://localhost:55432/horizon)
SPRING_DATASOURCE_URL=
HORIZON_API_KEY=
HORIZON_SERVE_FRONTEND=false
HORIZON_CORS_ORIGINS=http://localhost:5173
# 기상청 API허브 authKey — https://apihub.kma.go.kr 지상관측 → 종관기상관측(ASOS) 활용신청
# (공공데이터포털 serviceKey를 쓰는 경우 HORIZON_ASOS_PROVIDER=portal 로 변경)
HORIZON_KMA_API_KEY=
# HORIZON_ASOS_PROVIDER=apihub
# HORIZON_KMA_APIHUB_BASE_URL=https://apihub.kma.go.kr
# HORIZON_KMA_PM10_PATH=/api/typ01/url/dst_pm10_hr.php
# HORIZON_KMA_NORMALS_PATH=/api/typ01/url/sun_sfc_norm.php
# HORIZON_KMA_NORMALS_TMST=2021
# HORIZON_KMA_LIVING_BASE_PATH=/api/typ02/openApi/LivingWthrIdxServiceV3
# JWT 서명 키 (운영 환경에서는 반드시 변경)
JWT_SECRET=change-me-to-a-long-random-secret
HORIZON_AUTH_SEED_ADMIN=true

# ===== AI service (Python FastAPI) =====
AI_PORT=9800
HORIZON_AI_SERVICE_URL=http://localhost:9800

# ===== LLM =====
# 미설정 시 규칙 기반 코치로 자동 동작.
# Gemini 사용 예시:
#   OPENAI_API_KEY=<Google AI Studio 키>
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_MODEL=gemini-2.5-flash
# OpenAI 사용 시: OPENAI_BASE_URL 비우고 OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gemini-2.5-flash
