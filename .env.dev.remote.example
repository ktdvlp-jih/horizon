# Local dev — remote DB via SSH tunnel (Tailscale: scripts\ssh-db-tunnel-tailscale.bat)
# cp .env.dev.remote.example .env.dev

# ===== Database (remote via SSH tunnel) =====
POSTGRES_DB=horizon
POSTGRES_USER=horizon
POSTGRES_PASSWORD=horizon
POSTGRES_PORT=55432

# ===== Backend (Spring Boot, local) =====
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:55432/horizon
SPRING_DATASOURCE_USERNAME=horizon
SPRING_DATASOURCE_PASSWORD=horizon
HORIZON_API_KEY=
HORIZON_SERVE_FRONTEND=false
HORIZON_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
HORIZON_KMA_API_KEY=
# ASOS: https://www.data.go.kr → 기상청_지상(종관, ASOS) 시간자료 조회서비스
JWT_SECRET=horizon-dev-jwt-secret-change-me
HORIZON_AUTH_SEED_ADMIN=true

# ===== AI service (local Python, port 8000) =====
AI_PORT=8000
HORIZON_AI_SERVICE_URL=http://localhost:8000

# ===== LLM (optional) =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gemini-2.5-flash
